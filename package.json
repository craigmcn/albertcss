{
  "name": "albertcss",
  "version": "0.16.0",
  "description": "Personal CSS framework",
  "packageManager": "yarn@4.14.1",
  "type": "module",
  "scripts": {
    "build": "gulp build --env=production",
    "build:netlify": "gulp build --env=netlify",
    "dev": "gulp develop",
    "serve": "gulp serve",
    "format": "prettier --write src/",
    "lint": "./node_modules/.bin/eslint src/js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/craigmcn/albertcss.git"
  },
  "keywords": [
    "CSS",
    "framework"
  ],
  "author": "Craig McNaughton",
  "license": "GPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/craigmcn/albertcss/issues"
  },
  "homepage": "https://github.com/craigmcn/albertcss#readme",
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@vitest/coverage-v8": "^4.1.8",
    "babelify": "^10.0.0",
    "browser-sync": "^3.0.4",
    "browserify": "^17.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "formbouncerjs": "^1.4.6",
    "globals": "^17.6.0",
    "gulp": "^5.0.1",
    "gulp-autoprefixer": "^10.0.0",
    "gulp-if": "^3.0.0",
    "gulp-rename": "^2.1.0",
    "gulp-sass": "^6.0.1",
    "gulp-sourcemaps": "^3.0.0",
    "gulp-uglify": "^3.0.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "minimist": "^1.2.8",
    "neostandard": "^0.13.0",
    "prettier": "^3.8.4",
    "sass": "^1.100.0",
    "vinyl-buffer": "^1.0.1",
    "vinyl-source-stream": "^2.0.0",
    "vitest": "^4.1.8"
  }
}
